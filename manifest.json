{
  "manifest_version": 3,
  "name": "LinkedIn Bullshit Detector",
  "version": "1.0",
  "description": "Replaces LinkedIn engagement bait with honest summaries",
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://api.groq.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
